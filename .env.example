# ─── Configuración General ───────────────────────────────
JWT_SECRET=tu_secreto_super_seguro_aqui
HWID_SALT=sal_para_hmac_hardware

# ─── Supabase (Cloud Sync) ───────────────────────────────
# Usar la Service Role Key (secret) para bypass de RLS
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-service-role-key-de-supabase
SYNC_INTERVAL=30s                          # Intervalo de sincronización (ej: 30s, 2m, 5m)

# ─── Servidor Local ───────────────────────────────────────
PORT=8080
GIN_MODE=debug                             # Cambiar a release en producción

# ─── Database ─────────────────────────────────────────────
DB_PATH=./integritypos.db                  # Ruta al archivo SQLite local