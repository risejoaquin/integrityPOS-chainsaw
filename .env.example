# ═══════════════════════════════════════════════
# IntegrityPOS — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!

# ─── Environment ───────────────────────────────
# Values: "development" or "production"
ENV=development

# ─── Server ────────────────────────────────────
SERVER_PORT=8080

# ─── Database ──────────────────────────────────
DATABASE_PATH=integritypos.db

# ─── Security — REQUIRED (no defaults!) ────────
# Generate with: go run cmd/generate_keys/main.go
# Or Linux: openssl rand -base64 48
HMAC_SECRET=40gaB1aonWnqwj0+QCkg74s3iPeQf1Eb9M53kXRkBUlw4VBpWVLtd52dDJ+M0lAy
JWT_SECRET=wxf2b2P2OUETsbtEk8bsQppnlk0CFi5q+mfSdp9TExbuVyKRZLvFBWYL4VgLSyjv

# ─── Auth ──────────────────────────────────────
JWT_EXPIRATION_HOURS=24
BCRYPT_COST=12

# ─── Sync ──────────────────────────────────────
CLOUD_URL=
CLOUD_API_KEY=
SYNC_INTERVAL_SEC=30

# ─── Printer ───────────────────────────────────
# Modes: "stdout" (dev), "direct" (USB/serial)
PRINTER_MODE=stdout
PRINTER_DEVICE=/dev/usb/lp0

# ─── Fiscal (CFDI 4.0 — optional) ─────────────
# Leave empty to disable fiscal timbrado
FISCAL_PRIVATE_KEY_PATH=
FISCAL_CERT_PATH=
FISCAL_RFC=
FISCAL_NAME=
FISCAL_ADDRESS=

# ─── Backup ────────────────────────────────────
BACKUP_DIR=./backups
# Optional — if empty, backups are not encrypted
BACKUP_ENCRYPTION_KEY=zkjRuwJBhtx7VwlAg5h21/PSnJklBexNhlfqsW198rQ=

# ─── WAL (SQLite) ──────────────────────────────
WAL_CHECKPOINT_INTERVAL_MINUTES=5
WAL_MAX_SIZE_MB=100

# ─── Rate Limiting ─────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20